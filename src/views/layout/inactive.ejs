<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Enlace inactivo</title>
    <link rel="icon" href="/img/favicon.ico" type="image/x-icon">
    <link href="https://fonts.cdnfonts.com/css/euclid-circular-a" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/7.0.1/css/all.min.css">
    <link rel="stylesheet" href="/css/style.css">
</head>

<body>
    <div class="url-details-container" style="margin-top: 100px; text-align: center;">
        <!-- Hero Section -->
        <section class="hero" style="padding: 60px 20px;">
            <i class="fa-solid fa-link-slash"
                style="font-size: 3rem; color: var(--danger-color); margin-bottom: 20px;"></i>
            <h1>Oops!</h1>
            <p
                style="margin-top: 15px; color: var(--text-secondary); max-width: 500px; margin-left: auto; margin-right: auto;">
                <%= typeof msg !=='undefined' ? msg : "El enlace que intentas acceder no está disponible o no existe."
                    %>
            </p>
        </section>
    </div>
</body>

</html>