{
    "compilerOptions": {
        "target": "ESNext",
        "module": "CommonJS",
        "outDir": "./dist",
        "rootDir": "./src",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "baseUrl": ".",
        "paths": {
            "@/*": ["./src/*"],
        },
        "typeRoots": ["./node_modules/@types", "./src/types"]
    },
    "exclude": ["node_modules", "dist"],
    "include": ["src"]
}